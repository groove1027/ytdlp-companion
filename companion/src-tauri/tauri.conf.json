{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-nightly-schema/main/schema.json",
  "productName": "All In One Helper",
  "version": "2.0.1",
  "identifier": "com.groove1027.all-in-one-helper",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "title": "All In One Helper",
        "width": 440,
        "height": 580,
        "resizable": false,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["allinonehelper"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "languages": ["English", "Korean"]
      }
    }
  }
}
