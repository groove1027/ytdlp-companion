# yt-dlp API Server 환경변수
# 이 파일을 .env 로 복사한 뒤 값을 수정하세요

# 서버 포트 (기본값: 3100)
PORT=3100

# API 인증 키 — 반드시 변경하세요!
# 터미널에서 생성: openssl rand -hex 32
API_KEY=여기에-랜덤-키를-넣으세요

# 허용할 프론트엔드 도메인 (CORS)
# 쉼표로 여러 개 가능: https://myapp.com,https://dev.myapp.com
ALLOWED_ORIGINS=https://your-app-domain.com

# yt-dlp 실행 파일 경로 (기본값: /usr/local/bin/yt-dlp)
YTDLP_PATH=/usr/local/bin/yt-dlp

# 최대 동시 요청 수 (기본값: 5)
MAX_CONCURRENT=5

# URL 캐시 유효 시간 (초, 기본값: 3600 = 1시간)
CACHE_TTL=3600

# 로그 레벨: debug, info, warn, error
LOG_LEVEL=info
