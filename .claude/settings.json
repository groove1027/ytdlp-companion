{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/mac_mini/Downloads/all-in-one-production-build4/.claude/hooks/pre-edit-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/mac_mini/Downloads/all-in-one-production-build4/.claude/hooks/pre-commit-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/mac_mini/Downloads/all-in-one-production-build4/.claude/hooks/post-edit-check.sh"
          }
        ]
      },
      {
        "matcher": "mcp__codex__codex|mcp__codex__review",
        "hooks": [
          {
            "type": "command",
