# Ralph generated files (inside .ralph/ subfolder)
.ralph/.call_count
.ralph/.last_reset
.ralph/.exit_signals
.ralph/status.json
.ralph/.ralph_session
.ralph/.ralph_session_history
.ralph/.claude_session_id
.ralph/.response_analysis
.ralph/.circuit_breaker_state
.ralph/.circuit_breaker_history

# Ralph logs and generated docs
.ralph/logs/*
!.ralph/logs/.gitkeep
.ralph/docs/generated/*
!.ralph/docs/generated/.gitkeep

# Environment files (API keys — 절대 커밋 금지)
.env
.env.*
.env.local

# General logs
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.temp/
.e2e-verified

# Build output
dist/

# Vitest 자동 생성 (커버리지 리포트, 임시 결과)
src/coverage/
src/test-results/
coverage/
.vitest-cache/

# Large media index data files (use Git LFS or external hosting)
src/public/data/media-*.json

# Node modules (if using Node.js projects)
node_modules/

# Python cache (if using Python projects)
__pycache__/
*.pyc

# Rust build (if using Rust projects)
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Ralph backup directories (created by migration)
.ralph_backup_*
.wrangler/
test/data/
test/output/
test/media-index-builder-package.zip
