# .ralphrc - Ralph project configuration
# Project: All-in-One Production v3.1

# Project identification
PROJECT_NAME="all-in-one-production-claudecode"
PROJECT_TYPE="typescript"

# Claude Code CLI command
CLAUDE_CODE_CMD="claude"

# Loop settings
MAX_CALLS_PER_HOUR=60
CLAUDE_TIMEOUT_MINUTES=20
CLAUDE_OUTPUT_FORMAT="json"

# Tool permissions — this project's specific needs
ALLOWED_TOOLS="Write,Read,Edit,Glob,Grep,Bash(cd *),Bash(npx tsc *),Bash(npm run *),Bash(npm *),Bash(ls *),Bash(cat *),Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *)"

# Session management
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24

# Task sources
TASK_SOURCES="local"

# Circuit breaker thresholds
CB_NO_PROGRESS_THRESHOLD=5
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70
CB_COOLDOWN_MINUTES=30
