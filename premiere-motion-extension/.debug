<?xml version="1.0" encoding="UTF-8"?>
<!--
  .debug — CEP 개발용 디버그 설정
  이 파일이 확장 루트에 있으면 서명 없이 로컬 개발 가능

  ⚠️ 배포 시에는 이 파일을 포함하지 않는다
-->
<ExtensionList>
  <Extension Id="com.groovelab.motionmaster.panel">
    <HostList>
      <Host Name="PPRO" Port="8088"/>
    </HostList>
  </Extension>
</ExtensionList>
