<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="12.0"
  ExtensionBundleId="com.groovelab.motionmaster"
  ExtensionBundleVersion="1.0.0"
  ExtensionBundleName="Motion Master"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <ExtensionList>
    <Extension Id="com.groovelab.motionmaster.panel" Version="1.0.0" />
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro 25.0+ (2025) through 26.x (2026) -->
      <Host Name="PPRO" Version="[25.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="12.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.groovelab.motionmaster.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/motionEngine.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Motion Master</Menu>
          <Geometry>
            <Size>
              <Height>700</Height>
              <Width>380</Width>
            </Size>
            <MinSize>
              <Height>500</Height>
              <Width>320</Width>
            </MinSize>
            <MaxSize>
              <Height>1200</Height>
              <Width>600</Width>
            </MaxSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./client/icons/icon-normal.png</Icon>
            <Icon Type="RollOver">./client/icons/icon-hover.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
